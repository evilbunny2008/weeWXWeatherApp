<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
	xmlns:app="http://schemas.android.com/apk/res-auto"
	xmlns:tools="http://schemas.android.com/tools"
	android:layout_width="match_parent"
	android:layout_height="0dp"
	android:layout_weight="1"
	android:importantForAutofill="noExcludeDescendants"
	android:orientation="vertical"
	tools:layout_height="700dp"
	tools:ignore="VisualLintBounds">

	<LinearLayout
		android:layout_width="match_parent"
		android:layout_height="match_parent"
		android:orientation="vertical"
		android:paddingHorizontal="16dp">

		<com.google.android.material.textfield.TextInputLayout
			android:id="@+id/til1"
			android:layout_width="match_parent"
			android:layout_height="wrap_content"
			android:layout_marginTop="20dp"
			android:hint="@string/fileURL"
			tools:ignore="VisualLintBounds">

			<com.google.android.material.textfield.TextInputEditText
				android:id="@+id/settings"
				android:layout_width="match_parent"
				android:layout_height="wrap_content"
				android:layout_marginTop="10dp"
				android:gravity="center_vertical"
				android:inputType="textUri"
				android:textSize="20sp"
				tools:ignore="VisualLintTextFieldSize,SpeakableTextPresentCheck" />
		</com.google.android.material.textfield.TextInputLayout>

		<com.google.android.material.materialswitch.MaterialSwitch
			android:id="@+id/show_indoor"
			android:layout_width="match_parent"
			android:layout_height="wrap_content"
			android:layout_marginTop="10dp"
			android:checked="true"
			android:minHeight="48dp"
			android:text="@string/indoor_readings"
			android:textSize="20sp"
			tools:ignore="VisualLintButtonSize,VisualLintBounds" />

		<com.google.android.material.materialswitch.MaterialSwitch
			android:id="@+id/metric_forecasts"
			android:layout_width="match_parent"
			android:layout_height="wrap_content"
			android:layout_marginTop="10dp"
			android:checked="true"
			android:minHeight="48dp"
			android:text="@string/metric"
			android:textSize="20sp"
			tools:ignore="VisualLintButtonSize,VisualLintBounds" />

		<com.google.android.material.materialswitch.MaterialSwitch
			android:id="@+id/rain_in_inches"
			android:layout_width="match_parent"
			android:layout_height="wrap_content"
			android:layout_marginTop="10dp"
			android:checked="false"
			android:minHeight="48dp"
			android:text="@string/rain_in_inches"
			android:textSize="20sp"
			tools:ignore="VisualLintButtonSize,VisualLintBounds" />

		<com.google.android.material.materialswitch.MaterialSwitch
			android:id="@+id/force_dark_mode"
			android:layout_width="match_parent"
			android:layout_height="wrap_content"
			android:layout_marginTop="10dp"
			android:checked="false"
			android:minHeight="48dp"
			android:text="@string/force_dark_mode"
			android:textSize="20sp"
			tools:ignore="VisualLintButtonSize,VisualLintBounds" />

		<com.google.android.material.materialswitch.MaterialSwitch
			android:id="@+id/wifi_only"
			android:layout_width="match_parent"
			android:layout_height="wrap_content"
			android:layout_marginTop="10dp"
			android:checked="false"
			android:minHeight="48dp"
			android:text="@string/update_over_wifi"
			android:textSize="20sp"
			tools:ignore="VisualLintButtonSize,VisualLintBounds" />

		<com.google.android.material.materialswitch.MaterialSwitch
			android:id="@+id/next_moon"
			android:layout_width="match_parent"
			android:layout_height="wrap_content"
			android:layout_marginTop="10dp"
			android:checked="true"
			android:minHeight="48dp"
			android:text="@string/next_moon"
			android:textSize="20sp"
			tools:ignore="VisualLintButtonSize,VisualLintBounds" />

		<com.google.android.material.materialswitch.MaterialSwitch
			android:id="@+id/use_exact_alarm"
			android:layout_width="match_parent"
			android:layout_height="wrap_content"
			android:layout_marginTop="10dp"
			android:checked="false"
			android:minHeight="48dp"
			android:text="@string/use_exact_alarm"
			android:textSize="20sp"
			tools:ignore="VisualLintButtonSize,VisualLintBounds" />

		<com.google.android.material.textview.MaterialTextView
			android:id="@+id/mtv1"
			android:layout_width="match_parent"
			android:layout_height="wrap_content"
			android:ellipsize="none"
			android:gravity="bottom"
			android:scrollHorizontally="false"
			android:singleLine="false"
			android:text="@string/battery_warning"
			android:textSize="15sp"
			tools:ignore="VisualLintBounds" />

		<com.google.android.material.materialswitch.MaterialSwitch
			android:id="@+id/save_app_debug_logs"
			android:layout_width="match_parent"
			android:layout_height="wrap_content"
			android:layout_marginTop="10dp"
			android:checked="false"
			android:minHeight="48dp"
			android:text="@string/save_app_debug_logs"
			android:textSize="20sp"
			tools:ignore="VisualLintButtonSize,VisualLintBounds" />

		<com.google.android.material.textfield.TextInputLayout
			android:id="@+id/til2"
			style="@style/Widget.Material3.TextInputLayout.OutlinedBox.ExposedDropdownMenu"
			android:layout_width="match_parent"
			android:layout_height="wrap_content"
			android:layout_marginTop="10dp"
			android:hint="@string/refresh_time"
			android:labelFor="@id/spinner1"
			android:textSize="20sp"
			app:boxBackgroundMode="outline"
			app:boxStrokeColor="@color/Black"
			app:boxStrokeWidth="1dp"
			tools:ignore="VisualLintBounds">

			<com.google.android.material.textfield.MaterialAutoCompleteTextView
				android:id="@+id/spinner1"
				android:layout_width="match_parent"
				android:layout_height="wrap_content"
				android:clickable="true"
				android:focusable="true"
				android:inputType="none"
				android:saveEnabled="false"
				android:textSize="20sp"
				tools:ignore="SpeakableTextPresentCheck,VisualLintTextFieldSize,TouchTargetSizeCheck" />

		</com.google.android.material.textfield.TextInputLayout>

		<com.google.android.material.textfield.TextInputLayout
			android:id="@+id/til7"
			style="@style/Widget.Material3.TextInputLayout.OutlinedBox.ExposedDropdownMenu"
			android:layout_width="match_parent"
			android:layout_height="wrap_content"
			android:layout_marginTop="10dp"
			android:hint="@string/webcam_refresh_time"
			android:labelFor="@id/spinner5"
			android:textSize="20sp"
			app:boxBackgroundMode="outline"
			app:boxStrokeColor="@color/Black"
			app:boxStrokeWidth="1dp"
			tools:ignore="VisualLintBounds">

			<com.google.android.material.textfield.MaterialAutoCompleteTextView
				android:id="@+id/spinner5"
				android:layout_width="match_parent"
				android:layout_height="wrap_content"
				android:clickable="true"
				android:focusable="true"
				android:inputType="none"
				android:saveEnabled="false"
				android:textSize="20sp"
				tools:ignore="SpeakableTextPresentCheck,VisualLintTextFieldSize,TouchTargetSizeCheck" />

		</com.google.android.material.textfield.TextInputLayout>

		<com.google.android.material.textfield.TextInputLayout
			android:id="@+id/til3"
			style="@style/Widget.Material3.TextInputLayout.OutlinedBox.ExposedDropdownMenu"
			android:layout_width="match_parent"
			android:layout_height="wrap_content"
			android:layout_marginTop="10dp"
			android:hint="@string/forecast_interval"
			android:labelFor="@id/spinner4"
			android:textSize="20sp"
			app:boxBackgroundMode="outline"
			app:boxStrokeColor="@color/Black"
			app:boxStrokeWidth="1dp"
			tools:ignore="VisualLintBounds">

			<com.google.android.material.textfield.MaterialAutoCompleteTextView
				android:id="@+id/spinner4"
				android:layout_width="match_parent"
				android:layout_height="wrap_content"
				android:clickable="true"
				android:focusable="true"
				android:inputType="none"
				android:saveEnabled="false"
				android:textSize="20sp"
				tools:ignore="SpeakableTextPresentCheck,VisualLintTextFieldSize,TouchTargetSizeCheck" />

		</com.google.android.material.textfield.TextInputLayout>

		<com.google.android.material.textfield.TextInputLayout
			android:id="@+id/til4"
			style="@style/Widget.Material3.TextInputLayout.OutlinedBox.ExposedDropdownMenu"
			android:layout_width="match_parent"
			android:layout_height="wrap_content"
			android:layout_marginTop="10dp"
			android:hint="@string/app_theme"
			android:labelFor="@id/spinner2"
			android:textSize="20sp"
			app:boxBackgroundMode="outline"
			app:boxStrokeColor="@color/Black"
			app:boxStrokeWidth="1dp"
			tools:ignore="VisualLintBounds">

			<com.google.android.material.textfield.MaterialAutoCompleteTextView
				android:id="@+id/spinner2"
				android:layout_width="match_parent"
				android:layout_height="wrap_content"
				android:clickable="true"
				android:focusable="true"
				android:inputType="none"
				android:saveEnabled="false"
				android:textSize="20sp"
				tools:ignore="SpeakableTextPresentCheck,VisualLintTextFieldSize" />
		</com.google.android.material.textfield.TextInputLayout>

		<com.google.android.material.textfield.TextInputLayout
			android:id="@+id/til5"
			style="@style/Widget.Material3.TextInputLayout.OutlinedBox.ExposedDropdownMenu"
			android:layout_width="match_parent"
			android:layout_height="wrap_content"
			android:layout_marginTop="10dp"
			android:hint="@string/widget_theme"
			android:labelFor="@id/spinner2"
			android:textSize="20sp"
			app:boxBackgroundMode="outline"
			app:boxStrokeColor="@color/Black"
			app:boxStrokeWidth="1dp"
			tools:ignore="VisualLintBounds">

			<com.google.android.material.textfield.MaterialAutoCompleteTextView
				android:id="@+id/spinner3"
				android:layout_width="match_parent"
				android:layout_height="wrap_content"
				android:clickable="true"
				android:focusable="true"
				android:inputType="none"
				android:saveEnabled="false"
				android:textSize="20sp"
				tools:ignore="SpeakableTextPresentCheck,VisualLintTextFieldSize" />
		</com.google.android.material.textfield.TextInputLayout>

		<com.google.android.material.textfield.TextInputLayout
			android:id="@+id/bgTextInputLayout"
			android:layout_width="match_parent"
			android:layout_height="wrap_content"
			android:layout_marginTop="10dp"
			android:hint="@string/bgColour"
			android:visibility="gone"
			tools:ignore="VisualLintBounds">

			<com.github.evilbunny2008.colourpicker.CPEditText
				android:id="@+id/widgetBG"
				android:layout_width="match_parent"
				android:layout_height="wrap_content"
				android:clickable="true"
				android:focusable="true"
				android:gravity="center_vertical"
				android:minHeight="48dp"
				tools:ignore="VisualLintTextFieldSize,SpeakableTextPresentCheck" />
		</com.google.android.material.textfield.TextInputLayout>

		<com.google.android.material.textfield.TextInputLayout
			android:id="@+id/fgTextInputLayout"
			android:layout_width="match_parent"
			android:layout_height="wrap_content"
			android:layout_marginTop="10dp"
			android:hint="@string/fgColour"
			android:visibility="gone"
			tools:ignore="VisualLintBounds">

			<com.github.evilbunny2008.colourpicker.CPEditText
				android:id="@+id/widgetFG"
				android:layout_width="match_parent"
				android:layout_height="wrap_content"
				android:autofillHints="@string/fgColour"
				android:clickable="true"
				android:focusable="true"
				android:gravity="center_vertical"
				android:minHeight="48dp"
				tools:ignore="SpeakableTextPresentCheck,VisualLintTextFieldSize" />
		</com.google.android.material.textfield.TextInputLayout>

		<com.google.android.material.textview.MaterialTextView
			android:id="@+id/mtv2"
			android:layout_width="match_parent"
			android:layout_height="wrap_content"
			android:layout_marginTop="10dp"
			android:ellipsize="none"
			android:gravity="bottom"
			android:scrollHorizontally="false"
			android:singleLine="false"
			android:text="@string/radarforecast"
			android:textSize="20sp"
			tools:ignore="VisualLintBounds" />

		<RadioGroup
			android:layout_width="wrap_content"
			android:layout_height="wrap_content"
			android:layout_gravity="end"
			android:orientation="vertical"
			tools:ignore="VisualLintBounds">

			<com.google.android.material.radiobutton.MaterialRadioButton
				android:id="@+id/showRadar"
				style="@style/Widget.weeWXApp.RadioButtons"
				android:layout_width="wrap_content"
				android:layout_height="wrap_content"
				android:layout_gravity="center_vertical"
				android:checked="true"
				android:gravity="center_vertical"
				android:minHeight="48dp"
				android:padding="0dp"
				android:text="@string/show_radar" />

			<com.google.android.material.radiobutton.MaterialRadioButton
				android:id="@+id/showForecast"
				style="@style/Widget.weeWXApp.RadioButtons"
				android:layout_width="wrap_content"
				android:layout_height="wrap_content"
				android:layout_gravity="center_vertical"
				android:gravity="center_vertical"
				android:minHeight="48dp"
				android:text="@string/show_forecast" />
		</RadioGroup>

		<com.google.android.material.textfield.TextInputLayout
			android:id="@+id/til6"
			android:layout_width="match_parent"
			android:layout_height="wrap_content"
			android:layout_marginTop="10dp"
			android:hint="@string/custom_url"
			tools:ignore="VisualLintBounds">

			<com.google.android.material.textfield.TextInputEditText
				android:id="@+id/customURL"
				android:layout_width="match_parent"
				android:layout_height="wrap_content"
				android:gravity="center_vertical"
				android:inputType="textUri"
				android:minHeight="48dp"
				tools:ignore="SpeakableTextPresentCheck,VisualLintTextFieldSize,TextContrastCheck" />
		</com.google.android.material.textfield.TextInputLayout>

		<com.google.android.material.materialswitch.MaterialSwitch
			android:id="@+id/rainrate_alert_watch"
			android:layout_width="match_parent"
			android:layout_height="wrap_content"
			android:layout_marginTop="10dp"
			android:checked="false"
			android:minHeight="48dp"
			android:text="@string/rainrate_alert_watch"
			android:textSize="20sp"
			tools:ignore="VisualLintButtonSize,VisualLintBounds" />

		<com.google.android.material.materialswitch.MaterialSwitch
			android:id="@+id/rainrate_alert_warning"
			android:layout_width="match_parent"
			android:layout_height="wrap_content"
			android:layout_marginTop="10dp"
			android:checked="false"
			android:minHeight="48dp"
			android:text="@string/rainrate_alert_warning"
			android:textSize="20sp"
			tools:ignore="VisualLintButtonSize,VisualLintBounds" />

		<com.google.android.material.materialswitch.MaterialSwitch
			android:id="@+id/rainrate_alert_severe"
			android:layout_width="match_parent"
			android:layout_height="wrap_content"
			android:layout_marginTop="10dp"
			android:checked="false"
			android:minHeight="48dp"
			android:text="@string/rainrate_alert_severe"
			android:textSize="20sp"
			tools:ignore="VisualLintButtonSize,VisualLintBounds" />

		<com.google.android.material.materialswitch.MaterialSwitch
			android:id="@+id/rainfall_alert"
			android:layout_width="match_parent"
			android:layout_height="wrap_content"
			android:layout_marginTop="10dp"
			android:checked="false"
			android:minHeight="48dp"
			android:text="@string/rainfall_alert"
			android:textSize="20sp"
			tools:ignore="VisualLintButtonSize,VisualLintBounds" />

		<LinearLayout
			android:id="@+id/rainfall_setting"
			android:layout_width="match_parent"
			android:layout_height="wrap_content"
			android:orientation="vertical"
			android:visibility="gone">

			<LinearLayout
				android:layout_width="match_parent"
				android:layout_height="wrap_content"
				android:layout_marginTop="10dp"
				android:orientation="horizontal">

				<com.google.android.material.textview.MaterialTextView
					android:id="@+id/tvRainfallLimitLabel"
					style="@style/TextAppearance.Material3.DisplaySmall"
					android:layout_width="0dp"
					android:layout_height="wrap_content"
					android:layout_weight="1"
					android:gravity="start"
					android:text="@string/rainfall_limit"
					android:textSize="20sp" />

				<com.google.android.material.textview.MaterialTextView
					android:id="@+id/tvRainfallLimitValue"
					style="@style/TextAppearance.Material3.DisplaySmall"
					android:layout_width="wrap_content"
					android:layout_height="wrap_content"
					android:gravity="end"
					android:textSize="20sp" />

			</LinearLayout>

			<com.google.android.material.slider.Slider
				android:id="@+id/sliderRainfallLimit"
				android:layout_width="match_parent"
				android:layout_height="wrap_content"
				android:stepSize="1"
				app:haloRadius="0dp"
				app:labelBehavior="floating" />

			<LinearLayout
				android:layout_width="match_parent"
				android:layout_height="wrap_content"
				android:orientation="horizontal">

				<com.google.android.material.textview.MaterialTextView
					android:id="@+id/minRainfallLimit"
					style="@style/TextAppearance.Material3.BodySmall"
					android:layout_width="0dp"
					android:layout_height="wrap_content"
					android:layout_weight="1"
					android:gravity="start"
					android:textSize="20sp" />

				<com.google.android.material.textview.MaterialTextView
					android:id="@+id/maxRainfallLimit"
					style="@style/TextAppearance.Material3.BodySmall"
					android:layout_width="0dp"
					android:layout_height="wrap_content"
					android:layout_weight="1"
					android:gravity="end"
					android:textSize="20sp" />

			</LinearLayout>
		</LinearLayout>

		<com.google.android.material.materialswitch.MaterialSwitch
			android:id="@+id/morning_temp_alert"
			android:layout_width="match_parent"
			android:layout_height="wrap_content"
			android:layout_marginTop="10dp"
			android:checked="false"
			android:minHeight="48dp"
			android:text="@string/morning_temp_alert"
			android:textSize="20sp"
			tools:ignore="VisualLintButtonSize,VisualLintBounds" />

		<LinearLayout
			android:id="@+id/morning_temp_setting"
			android:layout_width="match_parent"
			android:layout_height="wrap_content"
			android:orientation="vertical"
			android:visibility="gone">

			<LinearLayout
				android:layout_width="match_parent"
				android:layout_height="wrap_content"
				android:layout_marginTop="10dp"
				android:orientation="horizontal">

				<com.google.android.material.textview.MaterialTextView
					android:id="@+id/tvMorningTempLabel"
					style="@style/TextAppearance.Material3.DisplaySmall"
					android:layout_width="0dp"
					android:layout_height="wrap_content"
					android:layout_weight="1"
					android:gravity="start"
					android:text="@string/temperature"
					android:textSize="20sp" />

				<com.google.android.material.textview.MaterialTextView
					android:id="@+id/tvMorningTempValue"
					style="@style/TextAppearance.Material3.DisplaySmall"
					android:layout_width="wrap_content"
					android:layout_height="wrap_content"
					android:gravity="end"
					android:textSize="20sp" />

			</LinearLayout>

			<com.google.android.material.slider.Slider
				android:id="@+id/sliderMorningTemp"
				android:layout_width="match_parent"
				android:layout_height="wrap_content"
				android:stepSize="1"
				app:haloRadius="0dp"
				app:labelBehavior="floating" />

			<LinearLayout
				android:layout_width="match_parent"
				android:layout_height="wrap_content"
				android:orientation="horizontal">

				<com.google.android.material.textview.MaterialTextView
					android:id="@+id/minMorningTemp"
					style="@style/TextAppearance.Material3.BodySmall"
					android:layout_width="0dp"
					android:layout_height="wrap_content"
					android:layout_weight="1"
					android:gravity="start"
					android:textSize="20sp" />

				<com.google.android.material.textview.MaterialTextView
					android:id="@+id/maxMorningTemp"
					style="@style/TextAppearance.Material3.BodySmall"
					android:layout_width="0dp"
					android:layout_height="wrap_content"
					android:layout_weight="1"
					android:gravity="end"
					android:textSize="20sp" />

			</LinearLayout>
		</LinearLayout>

		<com.google.android.material.materialswitch.MaterialSwitch
			android:id="@+id/afternoon_temp_alert"
			android:layout_width="match_parent"
			android:layout_height="wrap_content"
			android:layout_marginTop="10dp"
			android:checked="false"
			android:minHeight="48dp"
			android:text="@string/afternoon_temp_alert"
			android:textSize="20sp"
			tools:ignore="VisualLintButtonSize,VisualLintBounds" />

		<LinearLayout
			android:id="@+id/afternoon_temp_setting"
			android:layout_width="match_parent"
			android:layout_height="wrap_content"
			android:orientation="vertical"
			android:visibility="gone">

			<LinearLayout
				android:layout_width="match_parent"
				android:layout_height="wrap_content"
				android:layout_marginTop="10dp"
				android:orientation="horizontal">

				<com.google.android.material.textview.MaterialTextView
					android:id="@+id/tvAfternoonTempLabel"
					style="@style/TextAppearance.Material3.DisplaySmall"
					android:layout_width="0dp"
					android:layout_height="wrap_content"
					android:layout_weight="1"
					android:gravity="start"
					android:text="@string/temperature"
					android:textSize="20sp" />

				<com.google.android.material.textview.MaterialTextView
					android:id="@+id/tvAfternoonTempValue"
					style="@style/TextAppearance.Material3.DisplaySmall"
					android:layout_width="wrap_content"
					android:layout_height="wrap_content"
					android:gravity="end"
					android:textSize="20sp" />

			</LinearLayout>

			<com.google.android.material.slider.Slider
				android:id="@+id/sliderAfternoonTemp"
				android:layout_width="match_parent"
				android:layout_height="wrap_content"
				android:stepSize="1"
				app:haloRadius="0dp"
				app:labelBehavior="floating" />

			<LinearLayout
				android:layout_width="match_parent"
				android:layout_height="wrap_content"
				android:orientation="horizontal">

				<com.google.android.material.textview.MaterialTextView
					android:id="@+id/minAfternoonTemp"
					style="@style/TextAppearance.Material3.BodySmall"
					android:layout_width="0dp"
					android:layout_height="wrap_content"
					android:layout_weight="1"
					android:gravity="start"
					android:textSize="20sp" />

				<com.google.android.material.textview.MaterialTextView
					android:id="@+id/maxAfternoonTemp"
					style="@style/TextAppearance.Material3.BodySmall"
					android:layout_width="0dp"
					android:layout_height="wrap_content"
					android:layout_weight="1"
					android:gravity="end"
					android:textSize="20sp" />

			</LinearLayout>
		</LinearLayout>
	</LinearLayout>

	<LinearLayout
		android:layout_width="match_parent"
		android:layout_height="wrap_content"
		android:layout_marginTop="10dp"
		android:orientation="horizontal"
		tools:ignore="VisualLintBounds">

		<com.google.android.material.button.MaterialButton
			android:id="@+id/aboutButton"
			style="@style/Widget.weeWXApp.Button"
			android:layout_width="wrap_content"
			android:layout_height="wrap_content"
			android:layout_weight="1"
			android:minHeight="48dp"
			android:text="@string/about"
			android:textSize="18sp"
			tools:ignore="VisualLintButtonSize" />

		<com.google.android.material.button.MaterialButton
			android:id="@+id/saveButton"
			style="@style/Widget.weeWXApp.Button"
			android:layout_width="wrap_content"
			android:layout_height="wrap_content"
			android:layout_weight="1"
			android:minHeight="48dp"
			android:text="@string/save_settings"
			android:textSize="18sp"
			tools:ignore="VisualLintButtonSize" />
	</LinearLayout>

	<com.google.android.material.button.MaterialButton
		android:id="@+id/deleteData"
		style="@style/Widget.weeWXApp.Button"
		android:layout_width="match_parent"
		android:layout_height="wrap_content"
		android:layout_marginVertical="10dp"
		android:text="@string/delete_all_data"
		android:textSize="18sp"
		tools:ignore="VisualLintButtonSize,VisualLintBounds,TextContrastCheck" />
</LinearLayout>
